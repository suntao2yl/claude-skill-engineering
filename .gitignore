# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/

# IDE
.idea/
.vscode/

# Validation workspaces (dogfooding artifacts, not source)
validation/*/.engineering/
validation/*/.engineering-archive/
validation/*/.harness/
validation/*/.pytest_cache/
validation/*/__pycache__/

# but keep source code inside validation projects
!validation/*/lc.py
!validation/*/tests/
!validation/*/project.godot
!validation/*/scenes/
!validation/*/scripts/

# Engineering lifecycle state in the repo itself (if self-managed)
/.engineering/
/.engineering-archive/
